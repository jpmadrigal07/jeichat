# Shared monorepo env (repo root). Copy to `.env` and adjust.
# Apps load this file automatically in local dev.

# Better Auth (API is the auth server — see apps/api/src/auth/auth.ts)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of the API (must match where `/api/auth/*` is served)
BETTER_AUTH_URL=http://localhost:3001

# Primary DB: Neon Postgres (omit for local SQLite fallback — see apps/api/src/auth.ts)
# Use sslmode=verify-full in the query string to match future pg behavior and silence the
# "ssl modes prefer/require/verify-ca are aliases for verify-full" startup warning.
DATABASE_URL=
# Optional pg Pool size when using DATABASE_URL
PG_POOL_MAX=10

# Secondary storage: Upstash Redis — Better Auth uses this for session/cache reads off Postgres
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# API (Nest) — see apps/api/src/main.ts
PORT=3001
WEB_ORIGIN=http://localhost:3000
# Set to `false` to disable `Access-Control-Allow-Credentials` (defaults to enabled)
CORS_CREDENTIALS=

# Web (Next.js) — expose only non-secret values with NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=http://localhost:3001
# Required for session cookies on cross-origin requests to the API
NEXT_PUBLIC_API_CREDENTIALS=true
