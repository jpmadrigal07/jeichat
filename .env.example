# Shared monorepo env (repo root). Copy to `.env` and adjust.
# Apps load this file automatically in local dev.

# API (Nest) — see apps/api/src/main.ts
PORT=3001
WEB_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=

# Web (Next.js) — expose only non-secret values with NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=http://localhost:3001
